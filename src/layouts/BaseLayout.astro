---
import '../styles/global.css';
import { productionFlags, siteConfig } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Malerei Blaser — Präzision für Fassaden, Innenräume & Spezialtechniken',
  description = 'Moderne Malerarbeiten in Spiez: Fassaden, Innenräume, Spezialtechniken und persönliche Beratung mit klarer Offerte.'
} = Astro.props;
---
<!doctype html>
<html lang="de-CH">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteConfig.siteUrl} />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="#top" class="brand">{siteConfig.brandShort} <small>{siteConfig.location}</small></a>
        <nav class="site-nav" aria-label="Hauptnavigation">
          <a href="#leistungen">Leistungen</a>
          <a href="#galerie">Galerie</a>
          <a href="#prozess">Prozess</a>
          <a href="#kontakt">Kontakt</a>
        </nav>
      </div>
    </header>
    <main id="top">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container site-footer__inner footer-grid">
        <div>
          <p><strong>{siteConfig.businessName}</strong><br />Malerei & Oberflächen mit Schweizer Präzision.</p>
          {productionFlags.usingPlaceholderImages || productionFlags.usingPlaceholderTestimonials ? (
            <p class="footer-note">Hinweis: Referenzen und einzelne Inhalte werden vor dem Livegang noch finalisiert.</p>
          ) : null}
        </div>
        <div class="site-nav" aria-label="Footer Navigation">
          <a href={`mailto:${siteConfig.email}`}>E-Mail</a>
          <a href={siteConfig.phoneHref}>Telefon</a>
          {productionFlags.whatsappEnabled ? <a href={siteConfig.whatsappHref}>WhatsApp</a> : null}
        </div>
      </div>
    </footer>
  </body>
</html>
