---
import { productionFlags, siteConfig } from '../config/site';
---
<section class="hero">
  <div class="container hero__wrap">
    <div class="hero__copy">
      <span class="section__eyebrow">Malerei · Fassaden · Innenräume</span>
      <h1>Saubere Linien. Starke Farben. Solide Handwerksarbeit.</h1>
      <p>
        {siteConfig.brandShort} realisiert Fassaden, Wohnräume und Spezialoberflächen mit klarer Beratung,
        verlässlicher Ausführung und sichtbarer Liebe zum Detail — vom Einfamilienhaus bis zur Gewerbefläche.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href={siteConfig.phoneHref}>Jetzt anrufen</a>
        <a class="button button--accent" href="#kontakt">Offerte anfragen</a>
        {productionFlags.whatsappEnabled ? (
          <a class="button button--secondary" href={siteConfig.whatsappHref}>WhatsApp</a>
        ) : (
          <span class="button button--secondary button--disabled" aria-disabled="true">WhatsApp bald verfügbar</span>
        )}
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <strong>24h</strong>
          Reaktionszeit für neue Anfragen
        </div>
        <div class="hero__stat">
          <strong>3+</strong>
          klare CTA-Punkte für schnelle Kontaktaufnahme
        </div>
        <div class="hero__stat">
          <strong>CH</strong>
          lokal in {siteConfig.location} und im {siteConfig.region}
        </div>
      </div>
    </div>
    <aside class="hero__panel card">
      <img
        src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1200&q=80"
        alt="Stilvoll gestrichener Innenraum mit natürlichen Farbtönen"
      />
    </aside>
  </div>
</section>
