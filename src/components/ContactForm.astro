---
import { productionFlags, siteConfig } from '../config/site';
---
<section id="kontakt" class="section">
  <div class="container contact-grid">
    <div>
      <div class="section__header">
        <span class="section__eyebrow">Kontakt</span>
        <h2>Projekt besprechen und Offerte anfragen.</h2>
        <p class="lead">
          Kontaktmodul mit klarer Conversion-Struktur: Formular, Telefon und E-Mail in einem Blick.
        </p>
      </div>

      {productionFlags.formEnabled ? (
        <form class="contact-form card contact-card" action={siteConfig.formAction} method="POST">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="field">
            <label for="email">E-Mail</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label for="phone">Telefon</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" />
          </div>
          <div class="field">
            <label for="project">Projektbeschreibung</label>
            <textarea id="project" name="project" placeholder="Kurz beschreiben: Objekt, Umfang, gewünschter Termin …"></textarea>
          </div>
          <button class="button button--accent" type="submit">Offerte anfragen</button>
        </form>
      ) : (
        <div class="card contact-card contact-card--notice">
          <h3>Offerte anfragen</h3>
          <p>
            Das Online-Formular wird gerade für den Live-Betrieb vorbereitet. Bitte melden Sie sich bis dahin
            direkt per Telefon oder E-Mail.
          </p>
          <div class="hero__actions">
            <a class="button button--primary" href={siteConfig.phoneHref}>Anrufen</a>
            <a class="button button--accent" href={`mailto:${siteConfig.email}`}>E-Mail schreiben</a>
          </div>
        </div>
      )}
    </div>

    <aside class="contact-card card">
      <h3>Direkt erreichbar</h3>
      <div class="meta-list">
        <div>
          <strong>Telefon</strong>
          <a href={siteConfig.phoneHref}>{siteConfig.phoneDisplay}</a>
        </div>
        <div>
          <strong>E-Mail</strong>
          <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </div>
        {productionFlags.whatsappEnabled ? (
          <div>
            <strong>WhatsApp</strong>
            <a href={siteConfig.whatsappHref}>{siteConfig.whatsappDisplay}</a>
          </div>
        ) : null}
        <div>
          <strong>Standort</strong>
          {siteConfig.location}, {siteConfig.region}
        </div>
        <div>
          <strong>Antwortzeit</strong>
          {siteConfig.responseTime}
        </div>
      </div>
    </aside>
  </div>
</section>
